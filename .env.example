PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── Firebase Admin ────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=onlinemarket-e32e6
FIREBASE_PROJECT_ID=onlinemarket-e32e6

# Preferred: paste the full service account JSON from Firebase Console.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Alternate: set these individually from the service account JSON.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional: path to a service account JSON file (local dev only).
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Firebase client config JSON.
FIREBASE_CONFIG={"projectId":"onlinemarket-e32e6","storageBucket":"onlinemarket-e32e6.firebasestorage.app"}

# ── Cloudinary (image uploads) ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Razorpay (payments) ──────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Vercel Cron (optional) ───────────────────────────────────────────
CRON_SECRET=
